const eventService = require('../services/eventService');

const createEvent = async (req, res) => {
  try {
    // req.user was securely attached by the authenticateUser middleware
    const organiserId = req.user.id; 
    
    // Combine the request body with the secure organiser ID
    const eventData = { ...req.body, organiserId };

    const newEvent = await eventService.createEvent(eventData);
    res.status(201).json(newEvent);
  } catch (err) {
    res.status(400).json({ error: err.message });
  }
};

const getAllEvents = async (req, res) => {
  try {
    const events = await eventService.getAllEvents();
    res.status(200).json(events);
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
};


const getEventAttendees = async (req, res) => {
  try {
    const { id } = req.params; // The event ID from the URL
    const organiserId = req.user.id; // The logged-in Organiser's ID from the JWT token

    const data = await eventService.getEventAttendees(id, organiserId);
    
    res.status(200).json(data);
  } catch (err) {
    // If they aren't the owner, return a 403 Forbidden
    if (err.message.includes('Unauthorized')) {
      return res.status(403).json({ error: err.message });
    }
    res.status(404).json({ error: err.message });
  }
};

module.exports = { createEvent, getAllEvents, getEventAttendees };
