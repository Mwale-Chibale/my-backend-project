// Adapted from: AI Assistant (Gemini) response during iterative database design and setup.
// Source: Pair-programming session focused on relational database modeling for Event Management.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  // Note: url is strictly configured in prisma.config.ts in Prisma 7!
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  role      String    @default("ATTENDEE")
  createdAt DateTime  @default(now())
  
  events    Event[]   
  bookings  Booking[] 
}

model Event {
  id          Int       @id @default(autoincrement())
  title       String
  description String
  date        DateTime
  capacity    Int
  createdAt   DateTime  @default(now())
  
  organiserId Int
  organiser   User      @relation(fields: [organiserId], references: [id])
  bookings    Booking[]
}

model Booking {
  id        Int      @id @default(autoincrement())
  userId    Int
  eventId   Int
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  event     Event    @relation(fields: [eventId], references: [id])

  // Prevent double booking: A user can only book a specific event once
  @@unique([userId, eventId]) 
}